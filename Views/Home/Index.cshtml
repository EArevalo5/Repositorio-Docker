            </div>

            <div class="row g-3">
                <div class="col-md-4">
                    <div class="p-3 rounded-3 bg-secondary bg-opacity-10 border border-secondary border-opacity-25">
                        <span class="text-primary d-block small fw-semibold mb-1"><i class="bi bi-code-slash"></i> Dev 1</span>
                        <h6 class="mb-0 fw-bold text-white">Edgar Josué López Arévalo</h6>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-3 rounded-3 bg-secondary bg-opacity-10 border border-secondary border-opacity-25">
                        <span class="text-primary d-block small fw-semibold mb-1"><i class="bi bi-terminal"></i> Dev 2</span>
                        <h6 class="mb-0 fw-bold text-white">Elmer Leonel De la Cruz Fuentes</h6>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-3 rounded-3 bg-secondary bg-opacity-10 border border-secondary border-opacity-25">
                        <span class="text-primary d-block small fw-semibold mb-1"><i class="bi bi-layers"></i> Dev 3</span>
                        <h6 class="mb-0 fw-bold text-white">David Estuardo Cruz Garcia</h6>
                    </div>
                </div>
