@{
    ViewData["Title"] = "Inicio - DevOps con Contenedores";
}

<div class="container py-4 animate-fade-in" style="max-width: 900px;">

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white mb-4">
        <div class="card-body p-5">

            <div class="mb-3">
                <span class="badge bg-primary-subtle text-primary rounded-pill px-3 py-2 fw-semibold">
                    🚀 Proyecto MVC ASP.NET Core & DevOps
                </span>
            </div>

            <h1 class="display-4 fw-bold text-dark mb-3">
                Bienvenido a <span class="text-primary bg-gradient">DevOps Azure</span>
            </h1>

            <p class="text-secondary fs-5 lh-base mb-4" style="max-width: 750px;">
                Sitio web desarrollado bajo el patrón arquitectónico MVC, aplicando un empaquetado multi-etapa optimizado. Preparado para la integración y el despliegue continuo (CI/CD) en la nube de Microsoft Azure.
            </p>

            <div class="d-flex flex-wrap gap-2 mb-4">
                <a href="https://github.com/EArevalo5/Repositorio-Docker.git" target="_blank" class="btn btn-primary rounded-pill px-4 py-2 fw-semibold shadow-sm">
                    <i class="bi bi-github me-2"></i>Ver Repositorio
                </a>
                <a href="https://learn.microsoft.com/azure" target="_blank" class="btn btn-outline-secondary rounded-pill px-4 py-2 fw-semibold">
                    <i class="bi bi-cloud-fill me-2"></i>Documentación Azure
                </a>
            </div>

            <div class="d-flex flex-wrap gap-2 border-top pt-4 mb-2">
                <span class="badge bg-light text-success border border-success-subtle rounded-3 px-3 py-2">
                    <i class="bi bi-check-circle-fill me-1"></i> ASP.NET Core MVC
                </span>
                <span class="badge bg-light text-success border border-success-subtle rounded-3 px-3 py-2">
                    <i class="bi bi-check-circle-fill me-1"></i> Multi-Stage Dockerfile
                </span>
                <span class="badge bg-light text-success border border-success-subtle rounded-3 px-3 py-2">
                    <i class="bi bi-check-circle-fill me-1"></i> Diseño Responsivo
                </span>
                <span class="badge bg-light text-success border border-success-subtle rounded-3 px-3 py-2">
                    <i class="bi bi-check-circle-fill me-1"></i> Cloud Ready (Azure)
                </span>
