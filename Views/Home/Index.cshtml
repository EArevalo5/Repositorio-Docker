                <div class="d-flex align-items-center gap-3">
                    <div class="bg-success-subtle text-success rounded-3 p-2 fs-4"><i class="bi bi-cloud-arrow-up"></i></div>
                    <div>
                        <small class="text-muted d-block">Destino Cloud</small>
